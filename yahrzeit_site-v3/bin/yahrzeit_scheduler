#!/usr/bin/env php
<?php
/*
 * NAME
 *      yahrzeit_scheduler
 *
 * DESCRIPTION
 *      Scheduled phase runner for the CBS Yahrzeit Wall.
 *
 *      This script is intended to be run from cron at a few fixed times each
 *      day.  Cron decides when each phase runs; this script decides whether
 *      the requested phase applies today.
 *
 *      Supported phases:
 *
 *          --phase yizkor-on
 *              If today is a configured Yizkor day, run:
 *                  bin/yahrzeit --yizkor
 *              Otherwise do nothing.
 *
 *          --phase yizkor-off
 *              If today is a configured Yizkor day, restore normal lighting:
 *                  bin/yahrzeit
 *              Otherwise do nothing.
 *
 *          --phase yahrzeit
 *              Run normal yahrzeit lighting:
 *                  bin/yahrzeit
 *
 *      The normal scheduled-control path is:
 *
 *          cron
 *              -> bin/yahrzeit_scheduler
 *                  -> bin/yahrzeit
 *                      -> bin/yahrzeit_engine.php
 *                          -> controller command stream
 *                      -> nc
 *                          -> Arduino V3 controller
 *
 * BLUF
 *      cron decides WHEN scheduled phases run.
 *      yahrzeit_scheduler decides WHETHER the requested phase applies today.
 *      yahrzeit decides HOW to run/transmit.
 *      yahrzeit_engine.php decides WHAT names should be lit, audited, or reported.
 *
 *      Manual operator actions and web-page actions should normally call
 *      bin/yahrzeit directly, not this scheduler.
 *
 * HISTORY
 *      Version 1 created for Congregation Beth Sholom, 2007-2008
 *      by Allan M. Schwartz, allanschwartz@sbcglobal.net.
 *
 *      Version 2 was entirely in crontab.
 *      Version 3 modernized for PHP 8 in 2026.
 *
 * COPYRIGHT NOTICE
 *      Copyright (c) 2026, by Allan M. Schwartz.
 *      All rights reserved.
 */

require_once dirname(__DIR__) . "/include/misc.inc.php";

date_default_timezone_set("America/Los_Angeles");

function scheduler_usage()
{
    global $argv;
    $prog = basename($argv[0]);

    echo "Usage:\n";
    echo "  $prog --phase PHASE [options]\n\n";
    echo "Phases:\n";
    echo "  --phase yizkor-on     Run Yizkor lighting if today is a configured Yizkor day.\n";
    echo "  --phase yizkor-off    Restore normal yahrzeit lighting if today is a configured Yizkor day.\n";
    echo "  --phase yahrzeit      Run normal yahrzeit lighting.\n\n";
    echo "Options:\n";
    echo "  --dry-run             Show what would be run; do not call bin/yahrzeit.\n";
    echo "  --now 'YYYY-MM-DD HH:MM'\n";
    echo "                        Test as if the current time were the supplied time.\n";
    echo "  --verbose             Print non-action diagnostics.\n";
    echo "  -h, --help            Show this help.\n\n";
    echo "Typical cron entries:\n";
    echo "  0 11 * * * cd /path/to/yahrzeit_site-v3 && bin/yahrzeit_scheduler --phase yizkor-on  >> data/scheduler.log 2>&1\n";
    echo "  0 13 * * * cd /path/to/yahrzeit_site-v3 && bin/yahrzeit_scheduler --phase yizkor-off >> data/scheduler.log 2>&1\n";
    echo "  0 16 * * * cd /path/to/yahrzeit_site-v3 && bin/yahrzeit_scheduler --phase yahrzeit   >> data/scheduler.log 2>&1\n";
}

function fail($message)
{
    fwrite(STDERR, "yahrzeit_scheduler: $message\n");
    exit(1);
}

function parse_options($argv)
{
    $opts = array(
        'phase' => '',
        'dry_run' => false,
        'now' => time(),
        'verbose' => false,
    );

    for ($i = 1; $i < count($argv); $i++) {
        $arg = $argv[$i];

        switch ($arg) {
        case '-h':
        case '--help':
            scheduler_usage();
            exit(0);

        case '--dry-run':
            $opts['dry_run'] = true;
            break;

        case '--verbose':
            $opts['verbose'] = true;
            break;

        case '--now':
            $i++;
            if ($i >= count($argv)) {
                fail("--now requires 'YYYY-MM-DD HH:MM'");
            }
            $ts = strtotime($argv[$i]);
            if ($ts === false) {
                fail("invalid --now value: " . $argv[$i]);
            }
            $opts['now'] = $ts;
            break;

        case '--phase':
            $i++;
            if ($i >= count($argv)) {
                fail("--phase requires yizkor-on, yizkor-off, or yahrzeit");
            }
            $opts['phase'] = $argv[$i];
            break;

        default:
            fail("unknown option: $arg");
        }
    }

    if ($opts['phase'] == '') {
        fail("missing required --phase option");
    }

    switch ($opts['phase']) {
    case 'yizkor-on':
    case 'yizkor-off':
    case 'yahrzeit':
        break;
    default:
        fail("unknown phase: " . $opts['phase']);
    }

    return $opts;
}

function timestamp_line($message)
{
    global $log_now;

    $ts = isset($log_now) ? $log_now : time();
    echo date("Y-m-d H:i:s", $ts) . "  " . $message . "\n";
}

function bool_yes($value)
{
    return isset($value) && strtoupper(trim((string)$value)) == "YES";
}

function hebrew_date_parts($timestamp)
{
    $jd = gregoriantojd((int)date('n', $timestamp),
                        (int)date('j', $timestamp),
                        (int)date('Y', $timestamp));

    $hebrew = jdtojewish($jd);
    $parts = explode('/', $hebrew);

    if (count($parts) < 3) {
        return false;
    }

    return array(
        'month' => (int)$parts[0],
        'day' => (int)$parts[1],
        'year' => (int)$parts[2],
        'month_name' => jdmonthname($jd, 4),
    );
}

function yizkor_reasons_today($minhag, $now)
{
    global $english_month_mapping;
    global $hebrew_month_mapping;

    $reasons = array();
    $h = hebrew_date_parts($now);

    if ($h !== false) {
        // Yom Kippur: 10 Tishrei.
        // Yizkor is recited during the Yom Kippur service.
        if (bool_yes($minhag['yizkorYomKippur']) && $h['month'] == 1 && $h['day'] == 10) {
            $reasons[] = "Yom Kippur";
        }

        // Shemini Atzeret: 22 Tishrei.
        // Yizkor is recited during the Shemini Atzeret service.
        if (bool_yes($minhag['yizkorShmini']) && $h['month'] == 1 && $h['day'] == 22) {
            $reasons[] = "Shemini Atzeret";
        }

        // Pesach day 7 is 21 Nisan; day 8 is 22 Nisan.
        // The Minhag page allows only day 7 or day 8.
        if (bool_yes($minhag['yizkorPesach'])) {
            $pesach_day = isset($minhag['yizkorPesachDay']) ? (int)$minhag['yizkorPesachDay'] : 8;
            $nisan_day = ($pesach_day == 7) ? 21 : 22;

            if ($h['month'] == 8 && $h['day'] == $nisan_day) {
                $reasons[] = "Pesach day $pesach_day";
            }
        }

        // Shavuot day 1 is 6 Sivan; day 2 is 7 Sivan.
        // The Minhag page allows only day 1 or day 2.
        if (bool_yes($minhag['yizkorShavuot'])) {
            $shavuot_day = isset($minhag['yizkorShavuotDay']) ? (int)$minhag['yizkorShavuotDay'] : 2;
            $sivan_day = ($shavuot_day == 1) ? 6 : 7;

            if ($h['month'] == 10 && $h['day'] == $sivan_day) {
                $reasons[] = "Shavuot day $shavuot_day";
            }
        }

        // Other Yizkor-like Hebrew-date observance,
        // for example Yom HaZikaron on 4 Iyar.
        if (bool_yes($minhag['yizkorOther']) &&
            isset($minhag['otherEngOrHeb']) &&
            $minhag['otherEngOrHeb'] == 'heb') {

            $other_month_name = closest_hebrew_month(isset($minhag['otherHebMM']) ? $minhag['otherHebMM'] : "");
            $other_day = isset($minhag['otherHebDD']) ? (int)$minhag['otherHebDD'] : 0;

            if ($other_month_name != "" &&
                isset($hebrew_month_mapping[$other_month_name]) &&
                $h['month'] == $hebrew_month_mapping[$other_month_name] &&
                $h['day'] == $other_day) {
                $reasons[] = "Other Hebrew date: $other_day $other_month_name";
            }
        }
    }

    if (bool_yes($minhag['yizkorOther']) &&
        isset($minhag['otherEngOrHeb']) &&
        $minhag['otherEngOrHeb'] == 'eng') {

        $mm_name = isset($minhag['otherEngMM']) ? $minhag['otherEngMM'] : "";
        $dd = isset($minhag['otherEngDD']) ? (int)$minhag['otherEngDD'] : 0;

        if (isset($english_month_mapping[$mm_name]) &&
            (int)date('n', $now) == $english_month_mapping[$mm_name] &&
            (int)date('j', $now) == $dd) {
            $reasons[] = "Other English date: $mm_name $dd";
        }
    }

    return $reasons;
}

function run_yahrzeit_command($args, $reason, $opts)
{
    $cmd = escapeshellarg(__DIR__ . "/yahrzeit");

    foreach ($args as $arg) {
        $cmd .= " " . escapeshellarg($arg);
    }

    timestamp_line("ACTION: $reason");
    timestamp_line("COMMAND: $cmd");

    if ($opts['dry_run']) {
        return 0;
    }

    passthru($cmd, $rc);

    if ($rc != 0) {
        timestamp_line("ERROR: command exited with status $rc");
    }

    return $rc;
}

function main($argv)
{
    $opts = parse_options($argv);
    $now = $opts['now'];

    global $log_now;
    $log_now = $now;

    $minhag = read_minhag_ini();
    $phase = $opts['phase'];

    if ($phase == 'yahrzeit') {
        return run_yahrzeit_command(array(), "normal yahrzeit lighting", $opts);
    }

    $reasons = yizkor_reasons_today($minhag, $now);
    $is_yizkor_day = (count($reasons) > 0);
    $reason_text = $is_yizkor_day ? implode(", ", $reasons) : "not a configured Yizkor day";

    if ($phase == 'yizkor-on') {
        if ($is_yizkor_day) {
            return run_yahrzeit_command(array("--yizkor"), "Yizkor lighting on: $reason_text", $opts);
        }

        if ($opts['verbose']) {
            timestamp_line("No action: yizkor-on phase, $reason_text");
        }
        return 0;
    }

    if ($phase == 'yizkor-off') {
        if ($is_yizkor_day) {
            return run_yahrzeit_command(array(), "Yizkor service over; restore normal yahrzeit lighting: $reason_text", $opts);
        }

        if ($opts['verbose']) {
            timestamp_line("No action: yizkor-off phase, $reason_text");
        }
        return 0;
    }

    fail("unknown phase: $phase");
    return 1;
}

exit(main($argv));
