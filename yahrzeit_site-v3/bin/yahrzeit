#!/usr/bin/env bash
#
# NAME
#      bin/yahrzeit
#
# DESCRIPTION
#      Main command-line wrapper for the CBS Yahrzeit Wall.
#
#      This is the middle piece in the normal scheduled-control path:
#
#          cron
#              -> bin/yahrzeit_scheduler
#                  -> bin/yahrzeit
#                      -> bin/yahrzeit_engine.php
#                          -> controller command stream
#                      -> nc
#                          -> Arduino V3 controller
#
#      bin/yahrzeit is also the command a technical operator may run manually.
#      It provides one safe, common path for:
#
#          - normal yahrzeit lighting
#          - Yizkor lighting
#          - all-on / all-off operations
#          - controller status and diagnostic commands
#          - command-stream preview
#          - audit and report modes
#
#      For normal lighting, this script runs bin/yahrzeit_engine.php to generate the
#      line-oriented controller command stream, then transmits that stream to
#      the Arduino V3 controller using nc.
#
#      Report and audit modes also use bin/yahrzeit_engine.php, but do not transmit
#      anything to the controller.
#
#      Direct controller operations such as --all-on, --all-off, --status, and
#      --test generate their command streams here and transmit directly.
#
# BLUF
#      cron decides WHEN scheduled phases run.
#      yahrzeit_scheduler decides WHETHER the requested phase applies today.
#      yahrzeit decides HOW to run the action and, when appropriate, transmit it.
#      yahrzeit_engine.php decides WHAT names should be lit, audited, or reported.
#
#      This file should not contain calendar or Minhag rules.
#
# EXAMPLES
#      bin/yahrzeit
#      bin/yahrzeit --notransmit
#      bin/yahrzeit --yizkor
#      bin/yahrzeit --all-on
#      bin/yahrzeit --all-off
#      bin/yahrzeit --test 3
#      bin/yahrzeit --file commands.txt
#      bin/yahrzeit --host 192.168.86.240 --status
#      bin/yahrzeit --audit
#      bin/yahrzeit --report week
#      bin/yahrzeit --report month --date 2026-05-25
#
# NOTES
#      State-changing controller operations emit "save".
#
#      "load" is intentionally not sent. The Arduino controller loads saved
#      state autonomously on power-up.
#
#      This script uses nc for transport. 
#
# HISTORY
#      Version 3 created for Congregation Beth Sholom, 2007-2008
#      by Allan M. Schwartz, allanschwartz@sbcglobal.net.
#
# COPYRIGHT NOTICE
#      Copyright (c) 2008, 2026, by Allan M. Schwartz.
#      All rights reserved.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
YAHRZEIT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

PHP_BIN="$YAHRZEIT_DIR/bin/php"
CONTROLLER_HOST="192.168.13.9"
CONTROLLER_PORT="2001"
NC_DELAY="0.05"
POST_SEND_DELAY="0.5"

MODE="yahrzeit"
TRANSMIT=1
INPUT_FILE=""
TEST_NUMBER=""
BRIGHTNESS_VALUE=""
REPORT_KIND=""
REPORT_DATE=""
DEBUG_LEVEL=""

usage() {
    cat <<'EOF'
Usage:
  yahrzeit [options]

Default:
  yahrzeit
      Run yahrzeit_engine.php, then transmit generated commands.

Modes:
  --yizkor
      Send the current shortcut Yizkor lighting pattern.

  --all-on
      Turn all LEDs on, refresh, and save.

  --all-off
      Turn all LEDs off, refresh, and save.

  --te, --test N
      Run embedded controller self-test N.

  -f, --file FILE
      Send commands from FILE. Use "-" to read commands from stdin.

  --st, --status
      Ask controller for status.

  --ve, --version
      Ask controller for version.

  --he, --help-controller
      Ask controller for its help text.

  --br, --brightness N
      Set controller brightness. Controller convention: 1 is bright, 254 is dim.

Reports / dry-run modes:
  --audit
      Run yahrzeit_engine.php audit mode.  Output is printed; nothing is sent to the controller.

  --report KIND
      Run a yahrzeit report.  Output is printed; nothing is sent to the controller.
      Planned KIND values: day, week, next-week, month, next-month.

  --date YYYY-MM-DD
      Optional report date.  Used by report modes; ignored by controller-only modes.

  --debug N
      Pass debug level N to yahrzeit_engine.php for yahrzeit/audit/report modes.

Transmit/control options:
  --notransmit, --dry-run
      Print command stream to stdout instead of sending to controller.

  --ip, --host HOST
      Override controller host. Default: 192.168.13.9.

  --port PORT
      Override controller TCP port. Default: 2001.

  --nc-delay SECONDS
      Delay between lines for nc transmission. Default: 0.05.

  -h, --help
      Show this help.

Examples:
  yahrzeit
  yahrzeit --notransmit
  yahrzeit --yizkor
  yahrzeit --all-off
  yahrzeit --test 4
  yahrzeit --file saved-command-stream.txt
  yahrzeit --host 192.168.86.240 --status
  yahrzeit --audit
  yahrzeit --report week
  yahrzeit --report month --date 2026-05-25
EOF
}

php_assistance1() {
    cat >&2 <<EOF
yahrzeit: no usable PHP executable was found.

This command runs yahrzeit_engine.php, which uses PHP Calendar-extension functions
such as gregoriantojd(), jdtojewish(), jewishtojd(), and jdmonthname().

A historical PHP binary exists in this project at:

    $PHP_BIN

but on modern Macs it may fail with errors such as:

    bad CPU type in executable

On a modern Mac, install PHP with Homebrew:

    brew install php

Then verify PHP and the Calendar extension:

    php -v
    php -m | grep -i '^calendar$'
    php -r 'echo jdtojewish(gregoriantojd(5,22,2026)), PHP_EOL;'

After PHP is installed, rerun this command.
EOF
}

php_assistance2() {
    local php_cmd="$1"
    cat >&2 <<EOF
yahrzeit: PHP was found, but the PHP Calendar extension is missing.

PHP executable:

    $php_cmd

yahrzeit_engine.php requires PHP Calendar-extension functions such as:

    gregoriantojd()
    jdtojewish()
    jewishtojd()
    jdmonthname()

On a modern Mac using Homebrew, try:

    brew install php

Then verify:

    php -m | grep -i '^calendar$'
    php -r 'echo jdtojewish(gregoriantojd(5,22,2026)), PHP_EOL;'
EOF
}

die() {
    echo "yahrzeit: error: $*" >&2
    exit 1
}

set_mode() {
    local new_mode="$1"
    if [[ "$MODE" != "yahrzeit" ]]; then
        die "only one mode may be selected; already selected '$MODE', got '$new_mode'"
    fi
    MODE="$new_mode"
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --yizkor)
            set_mode "yizkor"
            shift
            ;;
        --all-on)
            set_mode "all-on"
            shift
            ;;
        --all-off)
            set_mode "all-off"
            shift
            ;;
        --audit)
            set_mode "audit"
            TRANSMIT=0
            shift
            ;;
        --br|--brightness)
            set_mode "brightness"
            [[ $# -ge 2 ]] || die "--brightness requires a number"
            BRIGHTNESS_VALUE="$2"
            [[ "$BRIGHTNESS_VALUE" =~ ^[0-9]+$ ]] || die "--brightness requires a numeric value"
            shift 2
            ;;
        --date)
            [[ $# -ge 2 ]] || die "--date requires YYYY-MM-DD"
            REPORT_DATE="$2"
            [[ "$REPORT_DATE" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || \
                die "--date requires YYYY-MM-DD"
            shift 2
            ;;
        --debug)
            [[ $# -ge 2 ]] || die "--debug requires a number"
            DEBUG_LEVEL="$2"
            [[ "$DEBUG_LEVEL" =~ ^[0-9]+$ ]] || die "--debug requires a numeric value"
            shift 2
            ;;
        -f|--file)
            set_mode "file"
            [[ $# -ge 2 ]] || die "--file requires a filename or '-'"
            INPUT_FILE="$2"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --he|--help-controller)
            set_mode "help-controller"
            shift
            ;;
        --host|--ip)
            [[ $# -ge 2 ]] || die "--host requires a value"
            CONTROLLER_HOST="$2"
            shift 2
            ;;
        --nc-delay)
            [[ $# -ge 2 ]] || die "--nc-delay requires a value"
            NC_DELAY="$2"
            shift 2
            ;;
        --notransmit|--dry-run)
            TRANSMIT=0
            shift
            ;;
        -p|--port)
            [[ $# -ge 2 ]] || die "--port requires a value"
            CONTROLLER_PORT="$2"
            [[ "$CONTROLLER_PORT" =~ ^[0-9]+$ ]] || die "--port requires a numeric value"
            shift 2
            ;;
        --report)
            set_mode "report"
            [[ $# -ge 2 ]] || die "--report requires a kind"
            REPORT_KIND="$2"
            case "$REPORT_KIND" in
                day|daily|week|weekly|next-week|month|this-month|next-month)
                    ;;
                *)
                    die "unknown report kind: $REPORT_KIND"
                    ;;
            esac
            TRANSMIT=0
            shift 2
            ;;

        --st|--status)
            set_mode "status"
            shift
            ;;
        --te|--test)
            set_mode "test"
            [[ $# -ge 2 ]] || die "--test requires a number"
            TEST_NUMBER="$2"
            [[ "$TEST_NUMBER" =~ ^[0-9]+$ ]] || die "--test requires a numeric test number"

            if (( TEST_NUMBER > 4 )); then
                POST_SEND_DELAY="20.00"
            fi

            shift 2
            ;;
        --ve|--version)
            set_mode "version"
            shift
            ;;
        *)
            die "unknown argument: $1"
            ;;
    esac
done

php_works() {
    local candidate="$1"

    [[ -x "$candidate" ]] || return 1
    "$candidate" -v >/dev/null 2>&1 || return 1

    return 0
}

find_php() {
    if php_works "$PHP_BIN"; then
        echo "$PHP_BIN"
        return 0
    fi

    if command -v php >/dev/null 2>&1; then
        local system_php
        system_php="$(command -v php)"

        if php_works "$system_php"; then
            echo "$system_php"
            return 0
        fi
    fi

    return 1
}

php_has_hebrew_calendar() {
    local php_cmd="$1"

    "$php_cmd" -r '
        exit(
            function_exists("gregoriantojd") &&
            function_exists("jdtojewish") &&
            function_exists("jewishtojd") &&
            function_exists("jdmonthname")
            ? 0 : 1
        );
    ' >/dev/null 2>&1
}

find_yahrzeit_php() {
    local php_cmd

    [[ -f "$SCRIPT_DIR/yahrzeit_engine.php" ]] || \
        die "missing $SCRIPT_DIR/yahrzeit_engine.php"

    if ! php_cmd="$(find_php)"; then
        php_assistance1
        exit 1
    fi

    if ! php_has_hebrew_calendar "$php_cmd"; then
        php_assistance2 "$php_cmd"
        exit 1
    fi

    echo "$php_cmd"
}

run_yahrzeitd() {
    local php_cmd

    php_cmd="$(find_yahrzeit_php)"

    if [ -n "${REPORT_DATE:-}" ] && [ -n "${DEBUG_LEVEL:-}" ]; then
        "$php_cmd" "$SCRIPT_DIR/yahrzeit_engine.php" "$@" --date "$REPORT_DATE" -d "$DEBUG_LEVEL"
    elif [ -n "${REPORT_DATE:-}" ]; then
        "$php_cmd" "$SCRIPT_DIR/yahrzeit_engine.php" "$@" --date "$REPORT_DATE"
    elif [ -n "${DEBUG_LEVEL:-}" ]; then
        "$php_cmd" "$SCRIPT_DIR/yahrzeit_engine.php" "$@" -d "$DEBUG_LEVEL"
    else
        "$php_cmd" "$SCRIPT_DIR/yahrzeit_engine.php" "$@"
    fi
}

# -----------------------------------------------------------------------------
# Command-stream emitters
# -----------------------------------------------------------------------------
#
# The following emit_*() functions produce the literal command streams that are
# sent to the Yahrzeit embedded controller.  The final command stream is either
# printed to stdout (--notransmit) or piped through slowcat/nc into the Arduino
# V3 appliance over TCP port 2001.
#
# Most of these heredocs use:
#
#       cat <<'EOF'
#
# rather than:
#
#       cat <<EOF
#
# The quoted heredoc delimiter means "emit this text literally": no shell
# variable expansion, no command substitution, and no backslash interpretation.
# That is the right behavior for fixed controller command streams such as:
#
#       all off
#       refresh
#       save
#
# Use an unquoted heredoc delimiter only when shell variables intentionally need
# to be expanded into the command stream.  For example, emit_brightness() needs
# "$BRIGHTNESS_VALUE", and emit_test() needs "$TEST_NUMBER", so those functions
# deliberately use:
#
#       cat <<EOF
#
# The embedded controller is instrumented to echo each command it executes, then
# return a result code and the elapsed time for that command.  Depending on the
# command, elapsed time may range from a few microseconds, to a few milliseconds,
# to many seconds for visual self-tests.
#
# The blank line after "save" and after "test <n>" is intentional.  It gives the
# controller and TCP connection one more line boundary, and keeps the socket open
# long enough for the controller to send back its echo/result/timing output.  Do
# not remove these blank lines merely because they look cosmetic.
# -----------------------------------------------------------------------------


emit_yahrzeit() {
    run_yahrzeitd
}

emit_audit() {
    run_yahrzeitd -a
}

emit_report() {
    run_yahrzeitd --report "$REPORT_KIND"
}

emit_yizkor() {
    # Shortcut Yizkor pattern, based on the later nc-era bin/yizkor wrapper.
    # These are the lights panels containing memorial names rather than trying
    # to compute every individual occupied LED from the database.
    cat <<'EOF'
# yizkor pattern .. most lights are on

all off
all on 1
all on 2
all on 3
all on 4
all on 5
all on 6
all on 7
all on 8
all on 9
all on 10
all off 11
all off 12
all on 13
all on 14
all off 15
all on 16
all off 17
all off 18
all on 19
all off 20
all off 21

refresh
save

EOF
}

emit_all_on() {
    cat <<'EOF'
all on
refresh
save

EOF
}

emit_all_off() {
    cat <<'EOF'
all off
refresh
save

EOF
}

emit_brightness() {
    cat <<EOF
brightness $BRIGHTNESS_VALUE
refresh
save

EOF
}

emit_file() {
    if [[ "$INPUT_FILE" == "-" ]]; then
        cat
    else
        [[ -f "$INPUT_FILE" ]] || die "command file not found: $INPUT_FILE"
        cat "$INPUT_FILE"
    fi
}

emit_help_controller() {
    cat <<'EOF'
help
EOF
}

emit_status() {
    cat <<'EOF'
status
EOF
}

emit_test() {
    cat <<EOF
test $TEST_NUMBER

EOF
}

emit_version() {
    cat <<'EOF'
version
EOF
}

# Dispatch to the selected command-stream emitter.
#
# Argument parsing above selects exactly one MODE.  This function converts that
# mode into the literal controller command stream that should be transmitted.
emit_commands() {
    case "$MODE" in
        yahrzeit)        emit_yahrzeit ;;
        audit)           emit_audit ;;
        report)          emit_report ;;
        yizkor)          emit_yizkor ;;
        all-on)          emit_all_on ;;
        all-off)         emit_all_off ;;
        brightness)      emit_brightness ;;
        file)            emit_file ;;
        help-controller) emit_help_controller ;;
        status)          emit_status ;;
        test)            emit_test ;;
        version)         emit_version ;;
        *)               die "internal error: unknown mode '$MODE'" ;;
    esac
}

# Slowly copy stdin to stdout, preserving line boundaries.
#
# The embedded controller accepts a simple line-oriented command language over
# TCP.  Although most V3 commands execute very quickly, pacing the stream avoids
# overrunning the controller's socket command parser and makes behavior more
# predictable during testing.
slowcat() {
    local delay="$1"
    while IFS= read -r line; do
        printf '%s\n' "$line"
        sleep "$delay"
    done
    sleep "$POST_SEND_DELAY"
}

# Either print the generated command stream or transmit it to the controller.
#
# In --notransmit / --dry-run mode, the command stream is simply printed to
# stdout for inspection.
#
# In normal mode, the stream is passed through slowcat and then into nc,
# connecting to the Yahrzeit embedded controller
transmit_commands() {
    if [[ "$TRANSMIT" -eq 0 ]]; then
        cat
        return
    fi

    command -v nc >/dev/null 2>&1 || die "nc not found"

    slowcat "$NC_DELAY" | nc "$CONTROLLER_HOST" "$CONTROLLER_PORT"
}

# Main pipeline:
#
#   1. Generate the selected controller command stream.
#   2. Either print it (--notransmit) or send it to the embedded controller.
emit_commands | transmit_commands
